{
  "name": "marp-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "strava:bootstrap": "bun run src/scripts/bootstrap-strava-webhook.ts",
    "admin:delete-athlete": "bun run src/scripts/admin-delete-athlete.ts",
    "admin:summarize-block": "bun run src/scripts/admin-summarize-block.ts",
    "admin:export-athlete": "bun run src/scripts/admin-export-athlete.ts",
    "eval:plan": "bun run src/scripts/eval-plan.ts",
    "eval:m1": "bun run src/scripts/eval-m1.ts",
    "reminders:run": "bun run src/scripts/run-reminders.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2"
  }
}
