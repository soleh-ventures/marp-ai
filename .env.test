# Test environment — auto-loaded by `bun test` (Bun sets NODE_ENV=test and
# reads .env.test). Committed on purpose: no secrets here, only local test
# defaults, so the suite runs green in any fresh checkout/worktree without
# manual env setup (fresh Conductor workspaces were failing 400+ tests on a
# missing DATABASE_URL — see investigation 2026-07-05).
#
# One-time machine setup (macOS):
#   brew services start postgresql@16
#   createdb marp_ai_test
#   DATABASE_URL=postgres://localhost:5432/marp_ai_test bun run src/db/migrate.ts
#
# No user in the URL — postgres.js defaults to the OS user (trust auth locally).
# src/db/test-guard.ts refuses destructive setup against Railway proxy hosts,
# so this can never point tests at prod.
DATABASE_URL=postgres://localhost:5432/marp_ai_test

# Offline LLM — tests must never hit the real API.
LLM_PROVIDER=mock

# Dummy 32-byte hex for token-cipher tests (NOT a real key; prod uses its own).
STRAVA_TOKEN_ENCRYPTION_KEY=6d617270746573746b65796d617270746573746b65796d617270746573746b65
