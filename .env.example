PORT=3000
NODE_ENV=development

# Postgres — Railway sets DATABASE_URL automatically in prod.
# Local dev: run `brew services start postgresql@16` then `createdb marp_ai_dev`.
DATABASE_URL=postgres://$USER@localhost:5432/marp_ai_dev

# Twilio (required in prod; set for sandbox testing)
TWILIO_AUTH_TOKEN=
# Override URL Twilio used to sign requests when behind ngrok/Railway proxy.
TWILIO_PUBLIC_WEBHOOK_BASE=
# DEV ONLY — bypass signature verification (1=skip). Ignored in prod.
SKIP_TWILIO_SIGNATURE=0

# Required for outbound replies (sending WhatsApp messages back).
TWILIO_ACCOUNT_SID=
TWILIO_WHATSAPP_FROM=

# Anthropic (T5 expert-router)
# Required when LLM_PROVIDER=anthropic. Set LLM_PROVIDER=mock for offline
# dev and tests.
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
# Optional model overrides — defaults shown.
# LLM_CLASSIFIER_MODEL=claude-haiku-4-5
# LLM_DOMAIN_MODEL=claude-sonnet-4-6
# LLM_SYNTHESIZER_MODEL=claude-sonnet-4-6

# ── Messaging channel (Telegram alternative to Twilio/WhatsApp) ──────────────
# whatsapp (default) | telegram | both. "telegram" routes everything through the
# bot and leaves WhatsApp code untouched but unused.
# MESSAGING_CHANNEL=telegram
# TELEGRAM_BOT_TOKEN=              # from @BotFather
# TELEGRAM_WEBHOOK_SECRET=         # optional; echoed by Telegram on each webhook POST
# TELEGRAM_PUBLIC_WEBHOOK_BASE=    # e.g. https://<host>  (for setWebhook)
# Personal link: attach your Telegram chat to your EXISTING athlete row (with
# your Strava + Garmin data) instead of creating a new one.
# TELEGRAM_DEFAULT_ATHLETE_ID=
