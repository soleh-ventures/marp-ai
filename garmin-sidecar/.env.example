# Copy to .env and fill in. .env is gitignored.

# Your own Garmin Connect login. Used once to mint a token; then the token in
# tokens/ is reused and these can be blanked. Never commit real values.
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Where the minted auth token is cached (dir). Treat contents like a password.
GARMIN_TOKEN_STORE=./tokens

# MARP Postgres (ingester step only; the probe does not need this).
# Local dev example: postgres://USER@localhost:5432/marp_ai_dev
DATABASE_URL=
